# MCP Cartographer API (local dev)
PORT=3333

# Web app (optional — defaults to GitHub repo)
# VITE_HUB_URL=https://your-docs-hub.example
# VITE_GITHUB_URL=https://github.com/DelfsEngineering/mcp-cartographer

# Hosted API → web CORS (optional — same-origin by default on Vercel)
# ALLOWED_ORIGINS=https://extra-origin.example

# Do not commit credentials.

MCP_DEV_NAME="My MCP Server"
MCP_DEV_URL="https://your-mcp-host.example/mcp"
MCP_DEV_X_API_KEY=""
MCP_DEV_X_BF_ENV_NAME=""
MCP_DEV_X_BF_ID_ENVIRONMENT=""
MCP_DEV_X_BF_ID_USER=""
